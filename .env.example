# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://finance:finance_secret@localhost:5432/finance_dev

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Secrets (MUST be changed in production - generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-min-64-chars-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-min-64-chars-change-in-production

# Token TTL (in seconds)
ACCESS_TOKEN_TTL=900           # 15 minutes
REFRESH_TOKEN_TTL=604800       # 7 days

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000        # 1 minute in milliseconds

# Argon2 Configuration
ARGON2_MEMORY=65536            # 64 MB
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:5173

# Logging
LOG_LEVEL=info                 # trace, debug, info, warn, error, fatal

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
